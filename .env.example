# =============================================================================
# Nuxt Studio — Custom Auth Configuration
# =============================================================================

# GitHub PAT (api scope) — commits content on behalf of all editors
# Create at: GitHub Settings → Personal access tokens and create a new Fine-grained Personal Access Token.
# https://nuxt.studio/git-providers#creating-a-github-personal-access-token
STUDIO_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Editor Allowlist — JSON array of authorized content editors
# =============================================================================
# Each entry: {"email": "...", "passwordHash": "$2b$12$...", "name": "..."}
#
# Generate password hashes:
#   node -e "import('bcryptjs').then(b => b.default.hash('your-password', 12).then(console.log))"
#
STUDIO_EDITORS=[{"email":"editor@example.com","passwordHash":"$2b$12$REPLACE_WITH_HASH","name":"Content Editor"}]
